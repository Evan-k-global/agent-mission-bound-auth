{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/agent-passport.schema.json",
  "type": "object",
  "required": ["version", "agentId", "agentIdentifier", "represents", "vouchedBy", "keyBinding", "passportId", "passportCommitment", "authorityJws"],
  "properties": {
    "version": { "const": "agent-passport-v1" },
    "agentId": { "type": "string", "minLength": 1 },
    "agentIdentifier": { "type": "string", "minLength": 1 },
    "represents": { "type": "object" },
    "vouchedBy": { "type": "array", "minItems": 1 },
    "keyBinding": { "type": "object" },
    "createdAt": { "type": "string" },
    "passportId": { "type": "string" },
    "passportCommitment": { "type": "string" },
    "authorityJws": { "type": "string" }
  }
}
