{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/registry-anchor.schema.json",
  "type": "object",
  "required": ["registryVersion", "sequence", "missionIdHash", "capabilityHash", "statementHash", "payloadDigest", "receiptIdHash", "nullifier", "previousRoot", "newRoot", "anchoredAt", "networkId", "proofHash", "anchorId"],
  "properties": {
    "registryVersion": { "const": "mba-registry-v1" },
    "sequence": { "type": "number" },
    "missionIdHash": { "type": "string" },
    "capabilityHash": { "type": "string" },
    "statementHash": { "type": "string" },
    "payloadDigest": { "type": "string" },
    "receiptIdHash": { "type": "string" },
    "nullifier": { "type": "string" },
    "previousRoot": { "type": "string" },
    "newRoot": { "type": "string" },
    "anchoredAt": { "type": "string" },
    "networkId": { "type": "string" },
    "registryAddress": { "type": ["string", "null"] },
    "txHash": { "type": ["string", "null"] },
    "proofHash": { "type": "string" },
    "anchorId": { "type": "string" }
  }
}
