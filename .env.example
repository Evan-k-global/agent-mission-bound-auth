HOST=127.0.0.1
PORT=8787
BASE_URL=http://127.0.0.1:8787
PUBLIC_BASE_URL=http://127.0.0.1:8787
DEMO_MODE=true
MISSION_AUTH_PROFILE=demo

# Demo issuer secret for local ZK OAuth proof simulation.
ZK_OAUTH_ISSUER_SECRET=local-demo-issuer-secret

# Real OIDC providers for sandbox testing.
# Auth0 callback: http://127.0.0.1:8787/api/oauth/callback
#
# For Auth0 SPA JS in the browser harness, configure the Auth0 app as a
# Single Page Application with:
# Allowed Callback URLs: http://127.0.0.1:8787
# Allowed Logout URLs: http://127.0.0.1:8787
# Allowed Web Origins: http://127.0.0.1:8787
AUTH0_ISSUER=https://your-auth0-tenant.us.auth0.com/
AUTH0_DOMAIN=your-auth0-tenant.us.auth0.com
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=
AUTH0_AUDIENCE=
AUTH0_SCOPE=openid profile email compute:clinical dataset:clinical-failures-q1 rail:zeko rail:base budget:small
VITE_AUTH0_DOMAIN=your-auth0-tenant.us.auth0.com
VITE_AUTH0_CLIENT_ID=

# Okta callback: http://127.0.0.1:8787/api/oauth/callback
# Use the org issuer for general SSO. Use /oauth2/default only after configuring
# an Okta authorization server access policy for this client.
OKTA_ISSUER=https://your-okta-domain.okta.com
OKTA_CLIENT_ID=
OKTA_CLIENT_SECRET=
OKTA_AUDIENCE=
OKTA_SCOPE=openid profile email

# Additional customer IdPs.
# OIDC_PROVIDERS_JSON='[{"provider":"customer-a","issuer":"https://idp.example.com","clientId":"...","clientSecret":"...","scope":"openid profile email"}]'
# Map verified provider subjects to internal agents.
# AGENT_MAPPINGS_JSON='[{"subjectKey":"okta:https://your-okta-domain.okta.com/:00u...","agentId":"agent-research-001","represents":{"type":"organization","id":"Acme"}}]'

# Seller / pay-to addresses for rails.
ZEKO_PAY_TO=B62qpBXMbrKVJwcS9wQN7SpFb6jkrXn2xrntCoM6D461qL2sYZarPHi
ZEKO_BENEFICIARY=B62qjxFhBZ2W1jzMyAppBkD22gGN66gTRYpX9AyaC4Kwga1kbC8zLBN
BASE_PAY_TO=0x1111111111111111111111111111111111111111
ETHEREUM_PAY_TO=0x2222222222222222222222222222222222222222
ARC_PAY_TO=0x3333333333333333333333333333333333333333
TEMPO_PAY_TO=0x4444444444444444444444444444444444444444

# Live Zeko endpoints.
ZEKO_GRAPHQL=https://testnet.zeko.io/graphql
ZEKO_ARCHIVE=https://archive.testnet.zeko.io/graphql
PRIVATE_COMPUTE_ZKAPP_PUBLIC_KEY=B62qpBXMbrKVJwcS9wQN7SpFb6jkrXn2xrntCoM6D461qL2sYZarPHi

# Aggregate-output policy.
PRIVATE_COMPUTE_MIN_COHORT=2
