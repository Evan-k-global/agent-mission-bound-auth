BASE_URL=https://your-sidecar.example
PUBLIC_BASE_URL=https://your-sidecar.example
DEMO_MODE=false
MISSION_AUTH_PROFILE=production
MAX_JSON_BODY_BYTES=1000000

# Enterprise OAuth / OIDC provider.
OIDC_ISSUER=https://your-idp.example.com/oauth2/default
OIDC_AUDIENCE=private-compute-api
OIDC_JWKS_URL=https://your-idp.example.com/oauth2/default/v1/keys

# Provider-specific OAuth login configs for the sidecar.
AUTH0_ISSUER=https://your-auth0-tenant.us.auth0.com/
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=
AUTH0_AUDIENCE=
OKTA_ISSUER=https://your-okta-domain.okta.com
OKTA_CLIENT_ID=
OKTA_CLIENT_SECRET=
OKTA_AUDIENCE=
OKTA_SCOPE=openid profile email

# Additional customer IdPs.
# OIDC_PROVIDERS_JSON='[{"provider":"customer-a","issuer":"https://idp.example.com","clientId":"...","clientSecret":"...","scope":"openid profile email"}]'
# Map verified provider subjects to internal agent records.
# AGENT_MAPPINGS_JSON='[{"subjectKey":"okta:https://your-okta-domain.okta.com/:00u...","agentId":"agent-research-001","represents":{"type":"organization","id":"Acme"}}]'

# Commitment issuer secret. Store outside git in production.
ZK_OAUTH_ISSUER_SECRET=replace-with-secret-manager-value
MISSION_AUTHORITY_PRIVATE_JWK={"kty":"EC","crv":"P-256","kid":"...","x":"...","y":"...","d":"..."}
MISSION_APPROVAL_BEARER_TOKEN=replace-with-approval-authority-token

# x402 settlement verification. Mock facilitator payments are disabled in production profile.
X402_TRUST_FACILITATOR_RECEIPTS=false

# Aggregate-output policy.
PRIVATE_COMPUTE_MIN_COHORT=3

# Zeko testnet.
ZEKO_GRAPHQL=https://testnet.zeko.io/graphql
ZEKO_ARCHIVE=https://archive.testnet.zeko.io/graphql
TX_FEE=2000000000

# Zeko deploy keys. Keep out of git.
DEPLOYER_PRIVATE_KEY=EK...
ZKAPP_PRIVATE_KEY=EK...
PRIVATE_COMPUTE_BENEFICIARY_PUBLIC_KEY=B62...

# x402 pay-to values.
ZEKO_PAY_TO=B62...
ZEKO_BENEFICIARY=B62...
PRIVATE_COMPUTE_ZKAPP_PUBLIC_KEY=B62...
ETHEREUM_PAY_TO=0x...
BASE_PAY_TO=0x...
ARC_PAY_TO=0x...
TEMPO_PAY_TO=0x...
